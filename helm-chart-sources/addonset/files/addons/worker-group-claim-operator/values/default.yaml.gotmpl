companyPrefix: {{ .Values.companyPrefix }}
manager:
  image:
    repository: prorobotech/worker-group-claim-operator
  tolerations:
    - key: "node-role.kubernetes.io/control-plane"
      operator: "Exists"
      effect: "NoSchedule"
    - key: "node-role.kubernetes.io/master"
      operator: "Exists"
      effect: "NoSchedule"

