manager:
  args:
  - --cluster-wide
  image:
    repository: prorobotech/certificate-set
    pullPolicy: IfNotPresent
  tolerations:
  - effect: NoExecute
    operator: Exists
  - effect: NoSchedule
    key: node-role.kubernetes.io/control-plane
metrics:
  enable: true
  port: 8443
networkPolicies:
  enabled: true

