vaultConfigs:
  default:
    spec:
      address: https://vault.{{ .Values.companyPrefix }}-vault.svc:8200
      tls:
        caBundleSecretRef:
          namespace: {{ .Values.companyPrefix }}-vault
          name: vault-tls-server
          key: ca.crt
        serverName: vault.{{ .Values.companyPrefix }}-vault.svc
