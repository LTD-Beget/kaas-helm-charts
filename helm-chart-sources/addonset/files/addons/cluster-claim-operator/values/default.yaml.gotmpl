manager:
  image:
    repository: prorobotech/cluster-claim-operator
  env:
  - name: ENABLE_WEBHOOKS
    value: false
  args:
    - --leader-elect
    - --remote-namespace={{ .Values.companyPrefix }}-system
    - --enable-webhook=false
  tolerations:
  - effect: NoExecute
    operator: Exists
  - effect: NoSchedule
    key: node-role.kubernetes.io/control-plane
