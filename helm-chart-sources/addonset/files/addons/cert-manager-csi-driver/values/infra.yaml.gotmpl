companyPrefix: {{ .Values.companyPrefix }}
networkPolicies:
  enabled: true
cert-manager-csi-driver:
  tolerations:
    - key: "node-role.kubernetes.io/control-plane"
      operator: "Exists"
      effect: "NoSchedule"
    - key: "node-role.kubernetes.io/master"
      operator: "Exists"
      effect: "NoSchedule"

