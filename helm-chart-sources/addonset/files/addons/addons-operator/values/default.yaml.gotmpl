certManager:
  enable: false
managerClaim:
  image:
    repository: prorobotech/addons-operator-addonclaim
webhook:
  enable: false
manager:
  env:
  - name: ENABLE_WEBHOOKS
    value: false
  image:
    repository: prorobotech/addons-operator
    pullPolicy: IfNotPresent
  tolerations:
  - effect: NoExecute
    operator: Exists
  - effect: NoSchedule
    key: node-role.kubernetes.io/control-plane
metrics:
  enable: false
  port: 8443

