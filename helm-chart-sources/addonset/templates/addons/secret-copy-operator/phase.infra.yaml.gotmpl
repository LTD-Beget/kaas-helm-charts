{{- if and .Values.addons.secretcopyoperator.enabled .Values.addons.system.enabled }}
  {{- $context  := deepCopy . -}}
  {{- $_        := set $context.Values "addonName"      "secret-copy-operator"          -}}
  {{- $_        := set $context.Values "suffix"         ""                 -}}
  {{- $_        := set $context.Values "parametersName" "parameters-infra" -}}

---
apiVersion: addons.in-cloud.io/v1alpha1
kind: AddonPhase
metadata:
  name: secret-copy-operator
spec:
  rules:
    {{- include "common.phase.rules.system"  $context | nindent 4 | include "common.trimEmptyLines" }}
{{- end }}
