{{- define "in-cloud-capi-template.files.security.90-high-load.conf" -}}
- path: /etc/security/limits.d/90-high-load.conf
  owner: root:root
  permissions: '0644'
  content: |
    # =============================================================================
    # /etc/security/limits.d/90-high-load.conf
    # Hard/soft лимиты для PAM-сессий (SSH, su, login).
    # Минимум: 1 CPU / 2 GB RAM
    #
    # Установка:
    #   sudo cp 90-high-load.conf /etc/security/limits.d/
    #
    # Проверка (из SSH-сессии нужного пользователя):
    #   ulimit -a
    #
    # ВАЖНО: для systemd-сервисов (nginx, postgres, приложение) эти лимиты
    # НЕ действуют — используйте LimitNOFILE / LimitNPROC в unit-файле
    # или systemd override (см. systemd.conf.d/limits.conf рядом).
    # =============================================================================


    # ─── nofile (открытые файлы / сокеты) ──────────────────────────────────────
    #
    # Что:    максимальное число открытых file descriptor'ов на процесс.
    #         Каждый TCP-сокет, файл, pipe, eventfd — один FD.
    #
    # Дефолт: soft=1024, hard=524288
    #         1024 — заложен в 1990-х; при тысячах одновременных соединений
    #         (reverse proxy, API gateway, БД) процесс получает "Too many open files"
    #         и перестаёт принимать новые подключения.
    #
    # Целевое: 1048576 (2^20)
    #
    # Аргументация:
    #   - Nginx/Envoy с 10K+ соединений потребляет ~20K FD (2 на проксированное).
    #   - Node.js/Go-сервис с пулами к БД, Redis, gRPC — легко 5K+ FD.
    #   - Kubernetes kubelet открывает watch'и на тысячи объектов.
    #   - Значение согласовано с fs.nr_open (потолок ядра), который по умолчанию = 1048576.
    #   - Само по себе не потребляет память — это лишь потолок, FD-таблица
    #     растёт только при реальном использовании (~240 байт на FD).
    #
    # Импакт:
    #   + Устраняет «Too many open files» при высокой нагрузке
    #   + Нет штрафа по памяти: неиспользованные FD не аллоцируются
    #   − Маскирует утечку FD — дополнить мониторингом: ls /proc/<pid>/fd | wc -l

    *    soft    nofile    1048576
    *    hard    nofile    1048576
    root soft    nofile    1048576
    root hard    nofile    1048576


    # ─── nproc (макс. процессов / потоков на пользователя) ──────────────────────
    #
    # Что:    лимит RLIMIT_NPROC — суммарное число процессов и потоков
    #         (task_struct) для данного UID.
    #
    # Дефолт: soft=hard = (RAM / 2 / 8KB стека) ≈ 63814 на 2 GB
    #         Формула ядра: threads-max/2 = max_threads/2.
    #         Дефолт уже близок к целевому, но не фиксирован — меняется
    #         от размера RAM. Фиксируем явно для воспроизводимости.
    #
    # Целевое: 65535
    #
    # Аргументация:
    #   - Защита от fork-бомбы: без лимита один пользователь может
    #     заспавнить столько процессов, что OOM-killer убьёт критичные сервисы.
    #   - 65535 — достаточно для Go (тысячи goroutine = потоки), Java (thread pool),
    #     containerd + shim'ы, а также запас для скриптов/cron.
    #   - На машинах с 2 GB RAM kernel.threads-max ≈ 127628;
    #     nproc=65535 — это ~51% от потолка, что оставляет запас для root.
    #
    # Импакт:
    #   + Фиксированный предсказуемый лимит на любой машине
    #   + Защита от неконтролируемого fork()
    #   − Если контейнерный рантайм создаёт shim на каждый Pod — на 500+ Pod
    #     может не хватить; тогда увеличить до 131072

    *    soft    nproc     65535
    *    hard    nproc     65535
    root soft    nproc     65535
    root hard    nproc     65535


    # ─── memlock (заблокированная в RAM память, KB) ─────────────────────────────
    #
    # Что:    лимит RLIMIT_MEMLOCK — сколько памяти процесс может
    #         заблокировать в RAM (mlock/mlockall), не допуская swap-out.
    #
    # Дефолт: soft=hard = 65536 KB (64 MB) или 8388608 KB на некоторых дистрибутивах
    #         На вашей машине: 2046952 KB (soft), systemd: 8388608 KB (8 GB??)
    #
    # Целевое: unlimited
    #
    # Аргументация:
    #   - eBPF-карты Cilium загружаются через mmap(BPF_MAP) с MAP_LOCKED.
    #     При memlock < размера карт — Cilium получает EPERM и не стартует.
    #     Типичное потребление Cilium: 50–300 MB mlock на ноде.
    #   - io_uring: регистрация буферов через IORING_REGISTER_BUFFERS блокирует
    #     страницы — при лимите 64 MB быстро упирается.
    #   - DPDK, RDMA, GPU-direct — все используют mlock.
    #   - unlimited не значит «потреблять всю RAM»: процесс блокирует только то,
    #     что явно запросил. OOM-killer всё равно сработает при исчерпании.
    #
    # Импакт:
    #   + Cilium/eBPF стартует без EPERM
    #   + io_uring, DPDK, GPU-direct работают без ограничений
    #   − Некорректная программа может заблокировать всю RAM — дополнить cgroup
    #     лимитом MemoryMax в systemd для конкретных сервисов

    *    soft    memlock   unlimited
    *    hard    memlock   unlimited
    root soft    memlock   unlimited
    root hard    memlock   unlimited


    # ─── core (размер core dump, KB) ───────────────────────────────────────────
    #
    # Что:    лимит RLIMIT_CORE — максимальный размер файла core dump
    #         при аварийном завершении процесса (SIGSEGV, SIGABRT и т.д.).
    #
    # Дефолт: soft=0, hard=infinity
    #         soft=0 означает: по умолчанию дамп не создаётся, но процесс
    #         может сам поднять лимит до infinity — и записать дамп любого размера.
    #
    # Целевое: hard=0
    #
    # Аргументация:
    #   - Core dump содержит полную память процесса: пароли, токены, ключи
    #     шифрования, PII — всё попадает в файл на диск в открытом виде.
    #   - Дамп Java/Go-процесса с 1 GB heap = 1 GB файл на диск. На сервере
    #     с 2 GB RAM это может заполнить / и вызвать каскадный отказ.
    #   - При hard=infinity любой процесс может включить дампы сам:
    #     setrlimit(RLIMIT_CORE, ...) — это дыра в безопасности.
    #   - hard=0 гарантирует, что ни один процесс не сможет создать дамп,
    #     даже если явно попросит.
    #
    # Импакт:
    #   + Нет утечки секретов через core dump
    #   + Нет риска заполнения диска аварийными дампами
    #   − Для отладки: временно убрать этот файл и перезайти в сессию,
    #     или задать LimitCORE=infinity в конкретном unit-файле

    *    soft    core      0
    *    hard    core      0


    # ─── stack (размер стека потока, KB) ───────────────────────────────────────
    #
    # Что:    RLIMIT_STACK — максимальный размер стека главного потока.
    #         Для дочерних потоков (pthread_create) стек по умолчанию = soft.
    #
    # Дефолт: soft=8192 (8 MB), hard=unlimited
    #
    # Целевое: soft=8192, hard=65536
    #
    # Аргументация:
    #   - 8 MB — стандарт для Linux, достаточный для большинства приложений.
    #   - hard=65536 (64 MB) — страховка для глубокой рекурсии (компиляторы,
    #     парсеры, regexp), при этом OOM-killer не допустит потребления всей RAM.
    #   - hard=unlimited (дефолт) позволяет процессу поднять стек до размера
    #     всей виртуальной памяти — на 2 GB RAM это опасно.
    #
    # Импакт:
    #   + Предсказуемое потребление стека
    #   + Защита от бесконечной рекурсии, съедающей RAM
    #   − Для JVM с глубоким стеком (>64 MB): увеличить через -Xss в JVM, а не тут

    *    soft    stack     8192
    *    hard    stack     65536
{{- end }}
