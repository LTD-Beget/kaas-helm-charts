{{- define "in-cloud-capi-template.files.sysctls.60-memory-disk.conf" -}}
- path: /etc/sysctl.d/60-memory-disk.conf
  owner: root:root
  permissions: '0644'
  content: |
    # =============================================================================
    # ПАМЯТЬ и ДИСК — управление swap, dirty-кэшем, лимитами
    # Целевое ядро: Linux 6.x | Статичный конфиг для нод 2–32 GB RAM
    #
    # Компромисс: ratio-параметры (%) масштабируются автоматически с RAM.
    # Абсолютные (min_free_kbytes) — консервативны для 2 GB, на 32 GB можно выше.
    #
    # Установка:
    #   sudo cp 60-memory-disk.conf /etc/sysctl.d/
    #   sudo sysctl --system
    # =============================================================================


    # ─── Swap ──────────────────────────────────────────────────────────────────

    # Склонность ядра к выталкиванию анонимных страниц в swap (0–200, дефолт 60).
    # 10 = агрессивно держать в RAM, swap — только в крайнем случае.
    # Импакт: стабильнее латентность; при реальной нехватке RAM — OOM быстрее.
    #   2 GB:  критично — каждый мегабайт на счету, swap = деградация latency.
    #   32 GB: менее критично, но 10 всё равно оптимально для серверных нагрузок.
    #          На 32 GB с большим page cache можно попробовать 5, но 10 — универсально.
    vm.swappiness = 10


    # ─── Dirty pages (фоновая запись на диск) ──────────────────────────────────

    # % RAM, при котором ядро НАЧИНАЕТ фоновый flush грязных страниц.
    # Импакт: чем меньше — тем раньше пишет и меньше пиков IO; но чаще дёргает диск.
    #   2 GB:  5% = 100 MB — фоновый flush начнётся рано, IO ровный.
    #   32 GB: 5% = 1.6 GB — по-прежнему разумно, данные не копятся.
    vm.dirty_background_ratio = 5

    # % RAM, при котором процесс БЛОКИРУЕТСЯ пока dirty pages не снизятся.
    # Импакт: защита от ситуации «скопилось Xгб dirty → всё зависло на sync».
    #   2 GB:  15% = 300 MB — процесс блокируется при 300 MB dirty. Безопасно.
    #   32 GB: 15% = 4.8 GB — ощутимо, но приемлемо; дефолт ядра 20% = 6.4 GB
    #          был бы хуже по latency. Если нужно строже — 10%, но 15% — баланс.
    vm.dirty_ratio = 15

    # Как часто (сотые доли секунды) pdflush/writeback проверяет dirty pages.
    # 300 = 3 секунды. Меньше — ровнее IO, но чаще CPU-wake.
    # Одинаково хорошо для 2 и 32 GB — не зависит от объёма RAM.
    vm.dirty_writeback_centisecs = 300

    # Возраст dirty page (сотые доли секунды), после которого она считается «старой»
    # и подлежит записи. 1500 = 15 секунд.
    # Импакт: грязные данные не залёживаются и меньше теряются при крэше.
    # Одинаково хорошо для 2 и 32 GB — не зависит от объёма RAM.
    vm.dirty_expire_centisecs = 1500


    # ─── Лимиты memory-mapped областей ────────────────────────────────────────

    # Максимум VMA (virtual memory areas) на процесс.
    # Нужно для Elasticsearch, JVM с большим heap, MongoDB и т.д.
    # Дефолт 65530 иногда мал; 1048576 — безопасно для серверных задач.
    #   2 GB:  процессы реально создают мало VMA — лимит не достигается.
    #   32 GB: ES/JVM с heap 16+ GB реально нуждается в высоком max_map_count.
    vm.max_map_count = 1048576


    # ─── Резерв свободных страниц ────────────────────────────────────────────

    # Минимум свободных KB, который ядро старается поддерживать.
    # При падении ниже — срабатывает kswapd (фоновый reclaim) раньше,
    # не дожидаясь direct reclaim (синхронный stall в аллокации).
    #   2 GB:  64 MB = 3.1% RAM — ощутимый резерв, но оправдан для стабильности.
    #          Не ставить выше 128 MB — иначе ядро будет слишком агрессивно
    #          reclaim'ить и приложения получат OOM раньше.
    #   32 GB: 64 MB = 0.2% RAM — почти незаметно, можно было бы 256 MB,
    #          но 64 MB — безопасный компромисс для единого конфига.
    vm.min_free_kbytes = 65536


    # ─── Pipe-буфер ────────────────────────────────────────────────────────────

    # Soft-лимит страниц pipe-буферов на пользователя (не блокирует, но предупреждает ядро).
    # Импакт: защита от ситуации «быстрый писатель / медленный читатель» съедает всю память.
    fs.pipe-user-pages-soft = 65536
{{- end }}
