{{- define "in-cloud-capi-template.files.sysctls.60-network.conf" -}}
- path: /etc/sysctl.d/60-network.conf
  owner: root:root
  permissions: '0644'
  content: |
    # =============================================================================
    # СЕТЬ — производительность и маршрутизация
    # Целевое ядро: Linux 6.x | Статичный конфиг для нод 2–32 GB RAM
    #
    # Компромисс: параметры безопасны для 2 GB (потолки, не аллокации).
    # На 32 GB работает хорошо, но буферы можно было бы поднять до 64–128 MB.
    #
    # Установка:
    #   sudo cp 60-network.conf /etc/sysctl.d/
    #   sudo sysctl --system
    # =============================================================================


    # ─── Маршрутизация ──────────────────────────────────────────────────────────

    # Разрешить пересылку IPv4-пакетов между интерфейсами.
    # Без этого K8s/NAT/VPN/прокси не маршрутизируют трафик.
    net.ipv4.ip_forward = 1

    # IPv6 forwarding — раскомментировать при dual-stack кластере или IPv6-шлюзе.
    # net.ipv6.conf.all.forwarding = 1
    # net.ipv6.conf.default.forwarding = 1

    # Bridge + iptables: нужен ТОЛЬКО при kube-proxy / Flannel bridge / Multus bridge.
    # Перед включением загрузите модуль: modprobe br_netfilter
    # Для чистого Cilium (eBPF) — НЕ раскомментировать.
    # net.bridge.bridge-nf-call-iptables  = 1
    # net.bridge.bridge-nf-call-ip6tables = 1


    # ─── Congestion control ────────────────────────────────────────────────────

    # Планировщик пакетов fq — оптимален в связке с BBR (pacing, fair queuing).
    net.core.default_qdisc = fq

    # BBR: congestion control на основе bandwidth+RTT, а не потерь пакетов.
    # Лучшая утилизация канала и меньше bufferbloat по сравнению с cubic/reno.
    net.ipv4.tcp_congestion_control = bbr


    # ─── Очереди входящих соединений ───────────────────────────────────────────

    # Максимум ожидающих accept() соединений на listen-сокете.
    # Это только потолок — реальная очередь растёт по мере поступления.
    # Согласовать с backlog nginx/haproxy/приложения.
    #   2 GB:  ~200 байт/запись, worst case ~12 MB — безопасно.
    #   32 GB: значение достаточно; на 100K+ RPS можно 131072, но 65536 покрывает.
    net.core.somaxconn = 65536

    # Очередь SYN-пакетов (до завершения трёхстороннего handshake).
    # Импакт: защита от SYN-flood + буфер при бурсте новых соединений.
    #   2 GB:  16384 × ~100 байт = ~1.6 MB worst case — безопасно.
    #   32 GB: при 50K+ новых conn/sec можно 32768, но 16384 — хороший баланс.
    net.ipv4.tcp_max_syn_backlog = 16384

    # Очередь входящих пакетов на NIC до обработки ядром (softirq).
    # Импакт: уменьшает дропы при пиках трафика; проверяйте /proc/net/softnet_stat.
    #   2 GB / 1 CPU: эффект ограничен (одно ядро обрабатывает последовательно).
    #   32 GB / 8+ CPU: ощутимый запас; при 10 Gbps+ можно 32768.
    net.core.netdev_max_backlog = 16384


    # ─── Буферы сокетов ───────────────────────────────────────────────────────

    # Потолки буферов для ЛЮБОГО сокета (TCP, UDP, unix).
    # 16 MB — безопасный потолок для диапазона 2–32 GB RAM.
    # Память аллоцируется только при реальном использовании (TCP autotuning).
    # На 2 GB: типичные буферы 100–500 KB, 16 MB — недостижимый потолок.
    # На 32 GB + 10 Gbps + 50ms RTT: BDP ≈ 62 MB, покрывается достаточно.
    net.core.rmem_max = 16777216
    net.core.wmem_max = 16777216

    # Дефолтные буферы для новых сокетов (до авто-тюна).
    #   2 GB:  1 MB — хорошо; 100 соединений × 1 MB = 100 MB, ядро не даст больше.
    #   32 GB: 1 MB достаточно; autotuning поднимет до max при необходимости.
    net.core.rmem_default = 1048576
    net.core.wmem_default = 1048576

    # TCP авто-тюн: min / default / max (байты).
    # min 4K — для idle; default 1M — начальный; max 16M — потолок.
    # Импакт: определяет пропускную способность одного TCP-потока (BDP = bandwidth × RTT).
    # На 2 GB: autotuning никогда не дотянет до 16 MB (не хватит трафика).
    # На 32 GB + быстрый канал: 16 MB реально используется.
    net.ipv4.tcp_rmem = 4096 1048576 16777216
    net.ipv4.tcp_wmem = 4096 1048576 16777216


    # ─── Эфемерные порты ──────────────────────────────────────────────────────

    # Диапазон ephemeral-портов смещён на 32768–60999, чтобы не пересекаться 
    # с типичными сервисными портами. Это снижает риск конфликтов между клиентскими 
    # (исходящими) соединениями и статически заданными портами в Kubernetes.
    # Ранее возникал случай когда kube-apiserver использовал порт для соединения 
    # с etcd, на котором должен был запуститься сервис, что приводило к ошибке 
    # bind (address already in use) при запуске сервисов с фиксированным портом.
    net.ipv4.ip_local_port_range = 32768 60999


    # ─── TCP: таймауты и keepalive ─────────────────────────────────────────────

    # Время ожидания FIN (секунды). Дефолт 60 — долго при массе коротких HTTP.
    # Импакт: быстрее освобождаются слоты TIME_WAIT.
    #   2 GB:  критично — меньше TIME_WAIT = меньше памяти на conntrack.
    #   32 GB: менее критично по памяти, но ускоряет переиспользование портов.
    net.ipv4.tcp_fin_timeout = 15

    # Первый keepalive-пинг через 300с (вместо 7200). Быстрее обнаружить dead peer.
    net.ipv4.tcp_keepalive_time = 300

    # Интервал между keepalive-пробами (секунды).
    net.ipv4.tcp_keepalive_intvl = 30

    # Количество проб до признания соединения мёртвым.
    net.ipv4.tcp_keepalive_probes = 5

    # Не сбрасывать cwnd после паузы в передаче — важно для HTTP keep-alive.
    # Импакт: повторные запросы по тому же соединению идут без slow-start.
    net.ipv4.tcp_slow_start_after_idle = 0


    # ─── TCP: оптимизации ─────────────────────────────────────────────────────

    # Разрешить TFO (TCP Fast Open) — передача данных уже в SYN.
    # Импакт: -1 RTT на первый запрос при повторных подключениях.
    # 3 = включён для клиента и сервера. Одинаково полезно на 2 и 32 GB.
    net.ipv4.tcp_fastopen = 3

    # Порог unsent-данных, при котором epoll/select «будит» приложение.
    # Дополняет BBR pacing, снижает задержку передачи.
    #   2 GB:  16 KB — оптимально для short-lived HTTP.
    #   32 GB: при streaming/gRPC с большими ответами можно 131072,
    #          но 16384 — безопасный универсальный дефолт.
    net.ipv4.tcp_notsent_lowat = 16384

    # tw_reuse=1: ядро может переиспользовать TIME_WAIT для ИСХОДЯЩИХ.
    #   2 GB:  критично — экономит conntrack-записи и порты.
    #   32 GB: менее критично по памяти, но ускоряет оборот портов при fan-out.
    net.ipv4.tcp_tw_reuse = 1

    # Conntrack — вынесен в отдельный файл 30-conntrack.conf.
{{- end }}
